# AI Report Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ===== REQUIRED =====
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ===== OPTIONAL (Defaults Provided) =====

# AI Model Configuration
# Options: gpt-4, gpt-3.5-turbo, gpt-4-turbo-preview
AGENT_MODEL=gpt-4

# Temperature controls creativity (0-1)
# 0 = deterministic/focused, 1 = creative/random
TEMPERATURE=0.7

# Maximum tokens per response
# Increase for longer responses, decrease to save costs
MAX_TOKENS=2000

# Request timeout in seconds
TIMEOUT=30

# Enable debug logging (true/false)
DEBUG=false

# ===== PATHS =====
# Path to reports directory
REPORTS_PATH=reports/

# Path to prompts directory
PROMPTS_PATH=prompts/

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
